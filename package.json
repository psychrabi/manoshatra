{
  "name": "manoshatra",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "cloudflare": {
    "label": "Vite React Template",
    "products": [
      "Workers"
    ],
    "categories": [],
    "preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
    "publish": true
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.6",
    "hono": "4.12.5",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.26.1",
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "10.0.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "^7.3.1",
    "wrangler": "4.71.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "d1:create": "wrangler d1 create manoshatra-db",
    "d1:setup": "bash setup-d1.sh",
    "d1:migrate": "wrangler d1 execute manoshatra-db --file=src/worker/schema.sql",
    "d1:seed": "wrangler d1 execute manoshatra-db --file=src/worker/seed.sql",
    "d1:local": "wrangler d1 execute manoshatra-db --local"
  },
  "type": "module"
}
